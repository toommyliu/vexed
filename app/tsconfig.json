{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "*": ["./*"],
    },
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    /* Completeness */
    "skipDefaultLibCheck": true,
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./dist/**/*",
    "./node_modules/"
  ]
}
